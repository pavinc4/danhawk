{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Danhawk",
  "version": "1.0.0",
  "identifier": "com.danhawk.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "Danhawk",
        "width": 900,
        "height": 600,
        "minWidth": 900,
        "minHeight": 600,
        "maxWidth": 900,
        "maxHeight": 600,
        "resizable": false,
        "decorations": false,
        "center": true,
        "devtools": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/AutoHotkey64.exe",
      "resources/python/*"
    ]
  }
}